# RevenueCat iOS public SDK key (safe in the Expo app)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_public_sdk_key

# Supabase (public — safe in the Expo app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostHog (public project token — safe in the Expo app)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_project_token
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com