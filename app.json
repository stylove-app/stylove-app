{
  "expo": {
    "name": "Stylove",
    "slug": "stylove-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "styloveapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Stylove uses your location to curate looks for your city and weather."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A121C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4A121C",
          "dark": {
            "backgroundColor": "#4A121C"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Stylove uses your location to curate looks for your city and weather."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Stylove accesses your photos to build your private wardrobe."
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
